ALTER VIEW [dbo].[BIFT_FA_VENDASGR_GRADE_VW] AS
SELECT
COALESCE(G.CD_CHAVE_GRADE, ' ') CD_CHAVE_GRADE,
COALESCE(G.NUMERACAO, ' ') CD_NUMERACAO,
COALESCE(G.LOTE, ' ') CD_LOTE,
COALESCE(G.ESPECIF3, ' ') CD_ESPECIF3,
COALESCE(G.SEQ_GRADE,' ') CD_SEQ_GRADE,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_CDD / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_CDD,
COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE, 0) MT_QUANTIDADE,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_TOTAL_ITEM / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_TOTAL_ITEM,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_ESTOQUE / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),5) MT_CUSTO_ESTOQUE,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_ICMS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_ICMS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_IPI / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_IPI,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_SUBSTITUICAO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_SUBSTITUICAO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_PIS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_PIS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_COFINS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_COFINS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_ISS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_ISS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_ENCARGOS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_ENCARGOS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_DESCONTO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_DESCONTO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_SEGURO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_SEGURO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_OUTRAS_DEPESAS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_OUTRAS_DEPESAS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_FRETE / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_FRETE,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_DESPESAS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_DESPESAS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_IRRF / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_IRRF,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_INSS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_INSS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VLR_COMISSAO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VLR_COMISSAO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_MATERIAIS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_MATERIAIS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_OP_DIRETO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_OP_DIRETO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_OP_INTEGRAL / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_OP_INTEGRAL,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_OP_ATVID / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_OP_ATVID,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_TERCEIROS / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_TERCEIROS,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_PRAZO_MEDIO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_PRAZO_MEDIO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_FINANC / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_FINANC,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_CUSTO_INCID_ADM / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_CUSTO_INCID_ADM,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VALOR_CONTABIL / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_VALOR_CONTABIL,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VALOR_DIFAL_ORIGEM / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_VALOR_DIFAL_ORIGEM,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VALOR_DIFAL_DESTINO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_VALOR_DIFAL_DESTINO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VALOR_ICMS_DISPENSADO / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),6) MT_VALOR_ICMS_DISPENSADO,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_TOTAL_ITEM_BASE / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_TOTAL_ITEM_BASE,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_VALOR_CONTABIL_BASE / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_VALOR_CONTABIL_BASE,
ROUND(CASE WHEN V.MT_QUANTIDADE = 0 THEN 0 ELSE (V.MT_FRETE_NOTA / V.MT_QUANTIDADE) END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE),2) MT_FRETE_NOTA,
V.CD_CHAVE_NF_ITEM,
V.CD_CHAVE_DOCUMENTO,
V.CD_MOVIMENTO,
V.CD_NF,
V.CD_SERIE,
V.CD_UNI_NEG,
V.CD_SEQUENCIAITEM,
V.CD_CLIENTE,
V.DATA,
V.CD_MATERIAL,
V.CD_ESPECIF1,
V.CD_ESPECIF2,
V.CD_TIPO_OPERACAO,
V.CD_COND_PAGAMENTO,
V.CD_TIPOFRETE,
V.CD_PEDIDOITEM,
V.CD_OPERACAORESULTADO,
V.CD_ESPECIEDOCUMENTO,
V.CD_UNIDADERESULTADO,
P.CD_CONTA_FINANCEIRA AS Cod_Conta,
F.DESC_CONTA_FINANCEIRA AS Conta_Desc
FROM CIGAM_BI.dbo.BIFT_FA_VENDASGR V WITH(NOLOCK)
LEFT JOIN CIGAM_BI.dbo.BIFT_FA_VENDASGR_GRADE G WITH(NOLOCK)
ON G.CD_MOVIMENTO = V.CD_MOVIMENTO
LEFT JOIN CIGAM_BI.dbo.BIFT_FA_PEDIDOSN P WITH(NOLOCK)
ON P.CD_PEDIDOITEM = V.CD_PEDIDOITEM
AND P.CD_SEQUENCIAITEM = V.CD_SEQUENCIAITEM
AND P.CD_OPERACAORESULTADO = V.CD_OPERACAORESULTADO
AND P.CD_CONTA_FINANCEIRA IN ('100101','100103')
LEFT JOIN CIGAM_BI.dbo.BIDM_GF_CONTA_FINANCEIRA F WITH(NOLOCK)
ON F.CD_CONTA_FINANCEIRA = P.CD_CONTA_FINANCEIRA;
GO
 
