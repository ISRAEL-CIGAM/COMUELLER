  SELECT
    SUM(
        ROUND(
            CASE 
                WHEN V.MT_QUANTIDADE = 0 THEN 0
                ELSE (V.MT_TOTAL_ITEM / V.MT_QUANTIDADE)
            END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE)
        , 6)
    ) AS Venda_Sem_IPI,

    SUM(COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE, 0)) AS Quantidade_Vendida,

    COUNT(DISTINCT V.CD_NF) AS Atendimentos,

    SUM(
        ROUND(
            CASE 
                WHEN V.MT_QUANTIDADE = 0 THEN 0
                ELSE (V.MT_TOTAL_ITEM / V.MT_QUANTIDADE)
            END * COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE)
        , 6)
    ) / NULLIF(COUNT(DISTINCT V.CD_NF), 0) AS Ticket_Medio,

    SUM(COALESCE(G.QUANTIDADE, V.MT_QUANTIDADE, 0))
    / NULLIF(COUNT(DISTINCT V.CD_NF), 0) AS Pecas_por_Atendimento

FROM CIGAM_BI.dbo.BIFT_FA_VENDASGR V WITH(NOLOCK)
LEFT JOIN CIGAM_BI.dbo.BIFT_FA_VENDASGR_GRADE G WITH(NOLOCK)
    ON G.CD_MOVIMENTO = V.CD_MOVIMENTO
LEFT JOIN CIGAM_BI.dbo.BIFT_FA_PEDIDOSN P WITH(NOLOCK)
    ON P.CD_PEDIDOITEM = V.CD_PEDIDOITEM
   AND P.CD_SEQUENCIAITEM = V.CD_SEQUENCIAITEM
   AND P.CD_OPERACAORESULTADO = V.CD_OPERACAORESULTADO
   AND P.CD_CONTA_FINANCEIRA = '100103'
WHERE P.CD_CONTA_FINANCEIRA IS NOT NULL
  AND V.DATA >= '2026-03-01'
  AND V.DATA < '2026-04-01';
